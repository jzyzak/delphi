# DELPHI environment template. Copy to `.env` and fill in real values.
#   cp .env.example .env
# `.env` is gitignored. Settings are read from the process environment
# (common/settings.py); secrets are resolved separately (common/secrets.py).

# --- Postgres spine (required for persistence; matches docker-compose.yml) ---
DELPHI_PG_DSN=postgresql://postgres:delphi@localhost:5432/delphi
# If host port 5432 is already in use, override it (docker-compose reads this)
# and point the DSN above at the same port:
# DELPHI_PG_PORT=5433

# --- Claude API (required for real LLM calls) --------------------------------
# DELPHI calls the Anthropic API directly. Get a key from the Claude Console:
# https://console.anthropic.com/ -> Settings -> API keys. Resolved via
# common/secrets.py (logical name `anthropic-api-key`).
DELPHI_SECRET_ANTHROPIC_API_KEY=sk-ant-your-key-here
# Transport selector: "anthropic" (default) or "bedrock" (see AWS block below).
# DELPHI_LLM_PROVIDER=anthropic

# --- Model tiers. Defaults (common/settings.py): Opus 4.8 for the workhorse
#     tier, Fable 5 for the strongest tier. Uncomment to override with other
#     Claude API model ids. ---
# DELPHI_MODEL_OPUS=claude-opus-4-8
# DELPHI_MODEL_FABLE=claude-fable-5

# --- AWS Bedrock (disabled; opt-in) ------------------------------------------
# To use Bedrock instead of the direct API: set DELPHI_LLM_PROVIDER=bedrock,
# uncomment DELPHI_AWS_REGION, override the model ids above with Bedrock-style
# ids (e.g. anthropic.claude-opus-4-8 / us.anthropic.claude-fable-5), and provide
# AWS creds via the standard chain (AWS_PROFILE / env keys / SSO / instance role).
# DELPHI_AWS_REGION=us-east-1

# --- Tavily search (required for real evidence retrieval) ---
# Logical secret name `tavily-api-key` -> this env var (common/secrets.py).
DELPHI_SECRET_TAVILY_API_KEY=tvly-your-key-here

# --- Evidence snapshots (optional; defaults to ~/.delphi/snapshots) ---
# DELPHI_SNAPSHOT_DIR=~/.delphi/snapshots

# --- Benchmarks (delphi eval / bench live) -----------------------------------
# Metaculus API token (optional; public question reads work without it).
# Logical secret name `metaculus-api-token` -> this env var (common/secrets.py).
# DELPHI_SECRET_METACULUS_API_TOKEN=your-metaculus-token
# ForecastBench dataset files for `delphi eval --suite forecastbench` and the
# `--suite forecastbench` live loop. Repo-relative paths (joined onto the public
# dataset repo) or absolute URLs. The resolution set is optional (open questions
# have no resolutions yet).
# DELPHI_FORECASTBENCH_QUESTION_SET=datasets/question_sets/latest-llm.json
# DELPHI_FORECASTBENCH_RESOLUTION_SET=datasets/resolution_sets/latest_resolution_set.json

# --- Live smoke suite gate (set to 1 to enable `pytest -m live`) ---
# DELPHI_LIVE_SMOKE=1
